# Copy to .env and fill in. Never commit .env.
# Get a key at https://aistudio.google.com/apikey

GEMINI_API_KEY=

# Master switch. false => app runs fully on rule-based summaries, no network needed.
GEMINI_ENABLED=false

# demo | clinical. Must stay "demo" while using a free-tier key:
# free-tier prompts and responses can be used to improve Google's products
# and may be reviewed by humans. No real patient data.
DATA_MODE=demo

GEMINI_NARRATION_MODEL=gemini-3.5-flash
GEMINI_CLASSIFIER_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECONDS=8
